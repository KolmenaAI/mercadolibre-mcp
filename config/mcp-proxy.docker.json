  "mcpProxy": {
    "addr": ":8000",
    "name": "mercadolibre-mcp",
    "version": "1.3.0",
    "type": "streamable-http",
    "options": {
      "logEnabled": true
    }
  },
  "mcpServers": {
    "meli": {
      "command": "mercadolibre-mcp",
      "args": [],
      "options": {
        "panicIfInvalid": false
      }
    }
  }
}
