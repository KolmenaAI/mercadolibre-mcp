{
  "$schema": "https://raw.githubusercontent.com/TBXark/mcp-proxy/master/schema.json",
  "mcpProxy": {
    "addr": ":8000",
    "name": "kolmena-mcp-meli-dev",
    "version": "1.0.0",
    "type": "streamable-http",
    "options": {
      "logEnabled": true
    }
  },
  "mcpServers": {
    "meli": {
      "command": "node",
      "args": ["bin/mcp-server.mjs"],
      "cwd": "/workspace/kolmena/meli-mcp",
      "options": {
        "panicIfInvalid": true
      }
    }
  }
}
