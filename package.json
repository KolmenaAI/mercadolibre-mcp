{
  "name": "@kolmena-ai/meli-mcp",
  "version": "1.3.0",
  "description": "Kolmena MercadoLibre MCP — buyer and seller tools: search, store ops, listings, orders, Q&A, claims.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "mercadolibre-mcp": "./bin/mcp-server.mjs",
    "meli-mcp": "./bin/mcp-server.mjs"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "start": "node bin/mcp-server.mjs",
    "inspector": "pnpm build && pnpm dlx @modelcontextprotocol/inspector node bin/mcp-server.mjs",
    "inspector:auth": "pnpm build && pnpm dlx @modelcontextprotocol/inspector -e MERCADOLIBRE_ACCESS_TOKEN=\"${MERCADOLIBRE_ACCESS_TOKEN}\" -- node bin/mcp-server.mjs",
    "smoke": "bash scripts/smoke-all-tools.sh"
  },
  "author": "KolmenaAI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KolmenaAI/mercadolibre-mcp.git"
  },
  "homepage": "https://github.com/KolmenaAI/mercadolibre-mcp#readme",
  "bugs": {
    "url": "https://github.com/KolmenaAI/mercadolibre-mcp/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.27.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
