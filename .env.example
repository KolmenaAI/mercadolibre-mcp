# Optional. Required for seller endpoints and some buyer calls.
# Obtain via Mercado Libre OAuth (authorization_code + token exchange).
MERCADOLIBRE_ACCESS_TOKEN=

# Web price enrichment (optional). When APIFY_TOKEN is set, the server recovers
# live website prices for catalog products that have no API buy-box price and
# returns them inline (price_source: "web"). One shared token for all agents —
# this is NOT the per-user Mercado Libre OAuth token and must not go in Bifrost.
APIFY_TOKEN=
APIFY_ML_ACTOR=sourabhbgp~mercadolibre-scraper
APIFY_TIMEOUT_MS=35000
SCRAPE_LIMIT=3
SCRAPE_CACHE_TTL_MS=600000
